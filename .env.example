# ==========================================================
#  Variables de entorno - App Ecologica (EcoX)
#  Copia este archivo como `.env` y rellena los valores reales.
#  Las llaves las encuentras en tu panel de Supabase:
#    Project Settings -> API
# ==========================================================

# --- Supabase ---
# URL del proyecto (Project Settings -> API -> Project URL)
SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Llave publica anon (Project Settings -> API -> Project API keys -> anon public)
SUPABASE_ANON_KEY=tu_supabase_anon_key

# --- Supabase Storage ---
# Nombre del bucket usado para imagenes de articulos y actividades
SUPABASE_STORAGE_BUCKET=markedplace
